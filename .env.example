SECRET_KEY=

ALGORITHM=

ACCESS_TOKEN_EXPIRE_MINUTES=

DATABASE_URL=

TRUST_PROXY_HEADERS=

CORS_ORIGINS=https://你的域名,http://你的公网IP

# 评论频率限制
COMMENT_RATE_LIMIT_PER_MINUTE=
COMMENT_RATE_LIMIT_PER_HOUR=

# 头像上传保存目录（相对于项目根目录）
AVATAR_UPLOAD_DIR=

# 默认头像的访问 URL（相对于静态文件根目录）
DEFAULT_AVATAR_URL=

# 头像大小上限5MB
MAX_AVATAR_SIZE=

# 管理员相关
ADMIN_PHONE=
ADMIN_1ST_PWD=
ADMIN_2ND_PWD=
QQ_EMAIL_FROM=
QQ_EMAIL_AUTH_CODE=
ADMIN_EMAIL_ALERT_TO=
ADMIN_PATH_PREFIX=/

# ai相关
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# 数据库备份专用（方便）
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
MYSQLDUMP_PATH=

# 日志配置
# 全局日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
# 控制台和文件只输出不低于此级别的日志
LOG_LEVEL=
# 是否将日志写入文件（true/false）
LOG_TO_FILE=
# 日志文件路径（自动创建目录）
LOG_FILE_PATH=
# 单个日志文件最大体积（字节），超过后立即切分（默认 10MB）
LOG_FILE_MAX_BYTES=
# 历史日志保留天数，超过后自动删除
LOG_FILE_RETENTION_DAYS=
# 时间轮转规则：每天午夜触发一次新的日志文件
LOG_TIME_ROTATE_WHEN=
# 时间轮转间隔天数（每天轮转）
LOG_TIME_ROTATE_INTERVAL=
# 是否以 JSON 格式输出日志（适合日志收集系统）
LOG_JSON=
# SQLAlchemy 数据库引擎日志级别（不低于 WARNING）
SQLALCHEMY_LOG_LEVEL=
# uvicorn 服务器日志级别（默认同 LOG_LEVEL，可单独调整）
UVICORN_LOG_LEVEL=